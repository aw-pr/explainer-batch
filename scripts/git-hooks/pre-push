#!/usr/bin/env bash
# Publish guard — pre-push. The PUBLIC repo (aw-pr/explainer-batch) may only
# receive its default branch. Any other remote (private backups) is
# unrestricted. Override once, intentionally: git push --no-verify
remote_name="$1"
remote_url="$2"
case "$remote_url" in
  *aw-pr/explainer-batch*) : ;;           # public — restricted below
  *) exit 0 ;;                            # private/backup — allow everything
esac
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master|"") : ;;
    *)
      echo "pre-push: '$remote_ref' blocked on PUBLIC remote '$remote_name'." >&2
      echo "          Only the default branch is public. Use --no-verify to" >&2
      echo "          override intentionally." >&2
      exit 1 ;;
  esac
done
exit 0
