# Copy to .env and fill in if you do NOT use 1Password.
#
# Loaded fill-only at startup (src/env.ts): a value here is used ONLY when the
# variable is not already set in the environment. It never overrides a real
# shell export or a key injected by the op-fetch / 1Password route, so it is
# safe to keep this file alongside a 1Password setup.
#
# .env.local takes precedence over .env (both gitignored except this .example).
# Provide whichever provider(s) you intend to use.

# --- Provider auth (set at least one) -------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Claude subscription (Max/Pro) sync route — generate with `claude setup-token`:
CLAUDE_CODE_OAUTH_TOKEN=

# --- Provider / model overrides (optional) --------------------------------
# PROVIDER=openai                 # default when no --provider flag: claude
# MODEL_BATCH=
# MODEL_LANE=
# MODEL_SYNTHESIS=
# MODEL_REPAIR=
# MAX_TOKENS=
# LANE_MAX_TOKENS=
# SYNTHESIS_MAX_TOKENS=
# REPAIR_MAX_TOKENS=

# --- Paths / integration (all optional) -----------------------------------
# Where source PDFs / urls.txt / focus sidecars are read from.
# Default: <repo>/input
# EXPLAINER_INPUT_DIR=/absolute/path/to/input
#
# Where generated explainers are written. Default: <repo>/output
# EXPLAINER_OUTPUT_DIR=/absolute/path/to/output
#
# Path to the consuming website repo. If unset, JSON staging and website-HTML
# export are skipped — the core pipeline still produces JSON in the output dir.
# WEBSITE_REPO=/absolute/path/to/website-repo
#
# Optional shared batch-dashboard jobs dir. Default: <repo>/jobs (best-effort).
# EXPLAINER_JOBS_DIR=/absolute/path/to/jobs

# 1Password users: leave this file empty and instead copy
# op-refs.local.sh.example to op-refs.local.sh with your vault refs.
