*.pdf

# Input directory: per-paper directive sidecars are local working state.
# Only the reference template stays tracked; everything else under input/
# (PDFs, real .focus.md sidecars, OS detritus) is local.
/input/*
!/input/.gitkeep
!/input/.focus.md.example


# Dependencies
node_modules/

# Environment
.env
.env.*
!.env.example

# Secrets / publish-guard (machine-specific; .example variants stay tracked)
*.local
op-refs.local.sh
.publish-guard.local

# Generated explainers: keep ONE tracked example, ignore everything else.
# Real runs should write elsewhere (EXPLAINER_OUTPUT_DIR / WEBSITE_REPO);
# the full local archive lives in the gitignored output.local/.
/output/*
!/output/.gitkeep
!/output/2026-04-16_alenezi_agentic-ai-architecture_explainer.json
!/output/2026-04-16_alenezi_agentic-ai-architecture_explainer.html
output.local/

# Local machine context notes (never publish)
/LOCAL.md

# Auto-managed state (machine-specific absolute paths)
state.json

# Local model overrides (.example stays tracked)
config/models.json

# Optional shared batch-dashboard integration
/jobs
/jobs/

# Build / coverage
dist/
build/
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS/editor
.DS_Store
.vscode/

# Claude Code runtime artefacts
.claude/
**/.claude/
